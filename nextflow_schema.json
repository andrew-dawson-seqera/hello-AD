{
    "$schema": "https://json-schema.org/draft-07/schema",
    "title": "Hello Pipeline Parameters",
    "description": "A super simple hello world pipeline",
    "type": "object",
    "properties": {
        "input": {
            "type": "string",
            "format": "file-path",
            "description": "Path to input file or samplesheet"
        },
        "outdir": {
            "type": "string",
            "format": "directory-path",
            "description": "The output directory where results will be saved"
        },
        "greeting": {
            "type": "string",
            "default": "Hello",
            "description": "The greeting to use",
            "enum": ["Hello", "Hola", "Bonjour", "Ciao"]
        }
    }
}
